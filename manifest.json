{
    "manifest_version": 3,
    "name": "Gerador de mensagens",
    "version": "1.1",
    "description": "Lê uma tabela de clientes e gera mensagens para copiar e colar.",
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardWrite",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "logo.png"
    },
    "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    }
}